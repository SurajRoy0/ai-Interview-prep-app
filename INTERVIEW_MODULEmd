## REPORT POLLING — NO ABLY NEEDED

```typescript
// src/app/interview/[id]/report/page.tsx
'use client'

import { useEffect, useState } from 'react'
import { getReportStatusAction } from '@/actions/report'

export default function ReportPage({ params }: { params: { id: string } }) {
  const [status, setStatus] = useState<'generating' | 'ready' | 'failed'>('generating')

  useEffect(() => {
    // Poll every 3 seconds until report is ready
    const poll = setInterval(async () => {
      const result = await getReportStatusAction(params.id)
      if (!result.success) return

      if (result.data.reportReady) {
        setStatus('ready')
        clearInterval(poll)
      }

      if (result.data.interviewStatus === 'FAILED') {
        setStatus('failed')
        clearInterval(poll)
      }
    }, 3000)

    return () => clearInterval(poll)
  }, [params.id])

  if (status === 'generating') {
    return <ReportGeneratingScreen />  // spinner + "Your report is being prepared"
  }

  if (status === 'failed') {
    return <ReportFailedScreen />
  }

  return <ReportReadyScreen interviewId={params.id} />
}
