## STREAMING ARCHITECTURE — NO ABLY

### How Vercel AI SDK streaming works in Server Actions

```typescript
// src/actions/interview.ts
'use server'

import { streamText } from 'ai'
import { createStreamableValue } from 'ai/rsc'
import { getGeminiModel, AI_MODELS } from '@repo/ai'

export async function submitTurnAction(input: SubmitTurnInput) {
  const session = await requireSession()

  // Validate
  const validated = submitTurnSchema.safeParse(input)
  if (!validated.success) return fail('INVALID_INPUT')

  const { interviewId, answer, inputMode } = validated.data

  // Load interview
  const interview = await prisma.interview.findUnique({
    where: { id: interviewId },
    include: { turns: { orderBy: { turnIndex: 'asc' } }, resume: true },
  })

  if (!interview) return fail('NOT_FOUND')
  if (interview.userId !== session.user.id) return fail('FORBIDDEN')
  if (interview.status !== 'ACTIVE') return fail('NOT_ACTIVE')

  // STEP 1: Save candidate turn FIRST — data never lost
  await prisma.interviewTurn.create({
    data: {
      interviewId,
      turnIndex: interview.currentTurnIndex + 1,
      role: 'USER',
      answer,
      inputMode: inputMode as any,
    },
  })

  // STEP 2: Check if last turn
  const isLastTurn = interview.currentTurnIndex + 1 >= interview.totalQuestions
  if (isLastTurn) {
    await completeInterviewInternal(interview)
    return ok({ isCompleted: true, stream: null })
  }

  // STEP 3: Check if activity triggers next
  const plan = interview.interviewPlan as InterviewPlan
  const nextActivity = plan.activities.find(
    a => a.insertAfterTurn === interview.currentTurnIndex + 1
  )
  if (nextActivity) {
    // Activity handled separately — return signal to frontend
    return ok({ isCompleted: false, stream: null, activityNext: true })
  }

  // STEP 4: Stream next AI response
  const stream = createStreamableValue('')

  // Run async — don't await, let it stream
  ;(async () => {
    try {
      const conversationHistory = buildConversationHistory(
        interview.turns,
        answer
      )

      const { textStream, usage } = await streamText({
        model: getGeminiModel(AI_MODELS.GEMINI.FLASH),
        system: buildInterviewSystemPrompt({
          plan,
          parsedData: interview.resume.parsedData as ResumeParsedData,
          currentTurnIndex: interview.currentTurnIndex + 1,
          totalTurns: interview.totalQuestions,
        }),
        messages: conversationHistory,
        maxTokens: 600,
        temperature: 0.4,
      })

      let fullText = ''
      for await (const delta of textStream) {
        fullText += delta
        stream.update(delta)  // each token sent to client
      }

      stream.done()  // streaming complete signal

      // STEP 5: Parse structured metadata from response
      const parsed = parseAITurnResponse(fullText)

      // STEP 6: Save AI turn to DB
      await prisma.interviewTurn.create({
        data: {
          interviewId,
          turnIndex: interview.currentTurnIndex + 2,
          role: 'AI',
          question: parsed.question,
          questionCategory: parsed.category as any,
          questionDifficulty: parsed.difficulty as any,
          psychologicalIntent: parsed.psychologicalIntent as any,
          targetSkills: parsed.targetSkills,
          inputMode: parsed.suggestedInputMode as any,
          isFollowUp: parsed.isFollowUp,
          followUpReason: parsed.followUpReason ?? null,
          turnScore: parsed.previousAnswerScore ?? null,
          topicScored: parsed.topicScored ?? null,
        },
      })

      // STEP 7: Update progress
      await prisma.interview.update({
        where: { id: interviewId },
        data: { currentTurnIndex: interview.currentTurnIndex + 2 },
      })

    } catch (err) {
      stream.error(err)
      await prisma.interview.update({
        where: { id: interviewId },
        data: { status: 'FAILED' },
      })
    }
  })()

  return ok({
    isCompleted: false,
    stream: stream.value,
    activityNext: false,
  })
}
```

### Frontend consumes the stream

```typescript
// src/app/interview/[id]/_components/ActiveInterview.tsx
'use client'

import { readStreamableValue } from 'ai/rsc'
import { useInterviewStore } from '@/store/interviewStore'

export function ActiveInterview({ interviewId }: { interviewId: string }) {
  const store = useInterviewStore()

  async function handleSubmit(answer: string, inputMode: string) {
    // Optimistically add user turn to display
    store.addTurn({ role: 'user', content: answer })
    store.setPhase('ai_typing')
    store.setStreamingText('')

    const result = await submitTurnAction({ interviewId, answer, inputMode })

    if (!result.success) {
      store.setPhase('failed')
      return
    }

    if (result.data.isCompleted) {
      store.setPhase('completed')
      return
    }

    if (result.data.activityNext) {
      // trigger activity flow
      await handleStartActivity()
      return
    }

    // Stream tokens into display — exactly like ChatGPT
    let fullText = ''
    for await (const delta of readStreamableValue(result.data.stream)) {
      if (delta) {
        fullText += delta
        store.setStreamingText(fullText)
      }
    }

    // Streaming complete — finalize
    const parsed = parseAITurnResponse(fullText)
    store.finalizeAITurn(parsed.question, parsed.suggestedInputMode)
    store.setPhase('waiting_input')
  }

  // ...rest of component
}
```

