export async function evaluateActivity(ctx: {
  activity: {
    type: string
    prompt: string
    codeSnippet?: string | null
    expectedAnswer: string  // NEVER sent to client
  }
  candidateAnswer: string
}): Promise<z.infer<typeof EvaluationSchema>> {

  const { object } = await generateObject({
    model: getGeminiModel(AI_MODELS.GEMINI.FLASH),
    schema: EvaluationSchema,
    prompt: `
You are evaluating a candidate's response to an interview activity.
Be honest. Do not inflate scores.

ACTIVITY TYPE: ${ctx.activity.type}
PROMPT: ${ctx.activity.prompt}
${ctx.activity.codeSnippet ? `CODE SHOWN:\n${ctx.activity.codeSnippet}` : ''}
EXPECTED ANSWER (internal — never show this): ${ctx.activity.expectedAnswer}

CANDIDATE RESPONSE:
${ctx.candidateAnswer || 'No response — candidate did not answer'}

Scoring rules:
  DEBUGGING: Found correct bug + explained = 80+. Found bug, no explanation = 60-75.
  CODE_CORRECTION: Fixed correctly + explained = 80+. Fixed but no reasoning = 60.
  OUTPUT_PREDICTION: Exact output = 90+. Minor error = 60-75. Wrong = 20-50.
  RESUME_DEFENCE: Deep accurate explanation = 80+. Surface only = 45-60. Couldn't defend = 20-40.
  PRIORITISATION: Logical order + sound reasoning = 80+. Some logic = 55-70. Random = 30.
  COMMUNICATION: Clear, simple, accurate = 80+. Accurate but complex = 55-65. Inaccurate = 30.
  SYSTEM_DESIGN_MINI: Covers key components + trade-offs = 80+. Partial = 50-70. Vague = 30.
    `,
  })

  return object
}
