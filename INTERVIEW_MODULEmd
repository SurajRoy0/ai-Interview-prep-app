## REPORT GENERATION

### Worker processor — no Ably, no notification

```typescript
// worker/src/processors/report.processor.ts

new Worker('report-generate', async (job) => {
  const { interviewId } = job.data

  const interview = await prisma.interview.findUniqueOrThrow({
    where: { id: interviewId },
    include: {
      turns: { orderBy: { turnIndex: 'asc' } },
      activities: true,
      resume: true,
      jobProfile: true,
    },
  })

  try {
    // Generate report with Gemini Flash
    const report = await generateReport(interview)

    // Save InterviewReport
    await prisma.interviewReport.create({
      data: {
        interviewId: interview.id,
        userId: interview.userId,
        overallScore: clamp(report.overallScore, 0, 100),
        communicationScore: clamp(report.communicationScore, 0, 100),
        technicalScore: clamp(report.technicalScore, 0, 100),
        confidenceScore: clamp(report.confidenceScore, 0, 100),
        authenticityScore: report.authenticityScore
          ? clamp(report.authenticityScore, 0, 100)
          : null,
        performanceSummary: report.performanceSummary,
        readinessLevel: report.readinessLevel,
        readinessSummary: report.readinessSummary,
        topStrengths: report.topStrengths,
        weakTopics: report.weakTopics,
        topicAnalysis: report.topicAnalysis,
        activitySummary: report.activitySummary ?? null,
        communicationAnalysis: report.communicationAnalysis,
        confidenceAnalysis: report.confidenceAnalysis,
        authenticityAnalysis: report.authenticityAnalysis ?? null,
      },
    })

    // Update interview scores
    await prisma.interview.update({
      where: { id: interviewId },
      data: {
        overallScore: clamp(report.overallScore, 0, 100),
        weakTopics: report.weakTopics.map((w: any) => w.topic),
        strongTopics: report.topStrengths,
      },
    })

    // Generate suggestions
    const suggestions = await generateSuggestions(interview, report)
    if (suggestions.length > 0) {
      await prisma.improvementSuggestion.createMany({
        data: suggestions.map((s: any) => ({
          ...s,
          interviewId: interview.id,
          userId: interview.userId,
        })),
      })
    }

    // No Ably publish — client is polling getReportStatusAction() every 3s
    console.log(`[Report] Ready — interviewId: ${interviewId}`)

  } catch (err) {
    console.error(`[Report] Failed — interviewId: ${interviewId}`, err)
    throw err // BullMQ retries on throw
  }

}, { connection, attempts: 3, backoff: { type: 'exponential', delay: 5000 } })
```

