{
  "name": "foxtel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "pnpm db:generate",
    "db:generate": "pnpm --filter @repo/db generate",
    "db:push": "pnpm --filter @repo/db push",
    "db:migrate": "pnpm --filter @repo/db migrate",
    "db:studio": "pnpm --filter @repo/db studio",
    "db:up": "docker compose up -d",
    "worker:dev": "pnpm --filter @repo/worker dev"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@repo/ai": "workspace:*",
    "@repo/audio": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/validators": "workspace:*",
    "ably": "^2.21.0",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-type": "^22.0.1",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
