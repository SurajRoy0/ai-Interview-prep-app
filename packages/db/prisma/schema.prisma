generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// ENUMS
// ======================================================

enum UserRole {
  CANDIDATE
  ADMIN
}

enum Ecosystem {
  JAVASCRIPT
  PYTHON
  JAVA
  GO
  OTHER
}

enum ExperienceLevel {
  FRESHER // 0 years
  JUNIOR // 0–2 years
  MID // 2–5 years
  SENIOR // 5+ years
}

enum InterviewStatus {
  PENDING // Created, plan generated, not yet started
  ACTIVE // Candidate answered first question
  COMPLETED // All turns done, report generating
  FAILED // Error or timeout — unrecoverable
  CANCELLED // User abandoned
}

enum InterviewType {
  MOCK // General practice
  TECHNICAL // Deep technical only
  HR // HR + behavioural only
  SYSTEM_DESIGN // Architecture focused
  BEHAVIORAL // Behavioural + communication
  FULL // HR + Technical + Activities (default)
}

enum InterviewMode {
  TEXT // Text input only
  VOICE // Voice input + TTS output
  MIXED // Voice input, text fallback
}

enum TurnRole {
  AI // Interviewer turn — contains question
  USER // Candidate turn — contains answer
}

enum ActivityType {
  DEBUGGING // Show broken code, candidate finds the bug
  CODE_CORRECTION // Show broken code, candidate fixes it in editor
  OUTPUT_PREDICTION // Show code, candidate predicts exact output
  RESUME_DEFENCE // Defend a specific resume claim
  PRIORITISATION // Rank/order production scenarios
  COMMUNICATION // Explain a concept simply to a fresher
  SYSTEM_DESIGN_MINI // Quick architecture sketch question
}

enum InputMode {
  VOICE // Candidate speaks only
  TEXT // Textarea only
  CODE_EDITOR // react-simple-code-editor only
  VOICE_AND_CODE // Voice explanation + editable code
  VOICE_AND_TEXT // Voice explanation + textarea
}

enum QuestionCategory {
  HR
  RESUME_BASED
  FOLLOW_UP_DEPTH
  CONCEPTUAL
  SCENARIO
  BEHAVIORAL
  PRESSURE
  REFLECTION
  COMMUNICATION_SIMPLIFICATION
  ACTIVITY
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum PsychologicalIntent {
  CONFIDENCE_CHECK // Warm up, build comfort
  DEPTH_PROBE // Go deeper on a topic
  PRESSURE_TEST // Challenge a claim or weak area
  CLARITY_CHECK // Assess communication quality
  REASONING_EVAL // Evaluate problem-solving process
  AUTHENTICITY_CHECK // Validate resume claim
  REFLECTION_TRIGGER // Force self-analysis
}

enum ImprovementPriority {
  CRITICAL // Fix before next interview
  HIGH // Important for target role
  MEDIUM // Good to address
  LOW // Nice to have
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum VisibilityStatus {
  PRIVATE
  PUBLIC
  RECRUITER_VISIBLE
}

// ======================================================
// USER
// Why: Core identity. Owns job profiles, billing, auth.
// ======================================================

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  role UserRole @default(CANDIDATE)

  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  visibilityStatus VisibilityStatus @default(PRIVATE)

  // Credit gate: first interview is free
  freeInterviewUsed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  jobProfiles   JobProfile[]
  interviews    Interview[]
  subscriptions Subscription[]
  payments      Payment[]
  credits       InterviewCredit[]
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
}

// ======================================================
// BETTER AUTH — SESSION
// Why: Required by Better Auth. Do not modify.
// ======================================================

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@map("AuthSession")
}

// ======================================================
// BETTER AUTH — ACCOUNT
// Why: Required by Better Auth. Handles Google OAuth + email.
// ======================================================

model Account {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId  String
  providerId String

  accessToken  String?
  refreshToken String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String?
  idToken  String?
  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// ======================================================
// BETTER AUTH — VERIFICATION
// Why: Required by Better Auth. Email verification tokens.
// ======================================================

model Verification {
  id String @id @default(cuid())

  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
}

// ======================================================
// JOB PROFILE
// Why: The primary preparation journey object.
//      "I am preparing for this specific role."
//      One user can have multiple profiles (Frontend + Backend etc.)
//      All interviews and resumes live inside a profile.
// ======================================================

model JobProfile {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String // e.g. "Frontend Engineer at Startups"
  targetRole  String // e.g. "Frontend Engineer"
  description String? // optional notes about the preparation goal

  experienceLevel ExperienceLevel
  ecosystem       Ecosystem?

  // Points to the resume snapshot used for future interviews.
  // Null until first resume is uploaded.
  // Updated when user uploads a new resume for this profile.
  activeResumeId String? @unique
  activeResume   Resume? @relation("ActiveResume", fields: [activeResumeId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  resumes    Resume[]
  interviews Interview[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([targetRole])
}

// ======================================================
// RESUME SNAPSHOT
// Why: Each upload creates a NEW immutable snapshot.
//      Interviews are frozen against the snapshot they were generated from.
//      Guarantees historical correctness and reproducible reports.
//      The parsed JSON is the source of truth — file is optional.
// ======================================================

model Resume {
  id String @id @default(cuid())

  jobProfileId String
  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)

  // File storage — optional (you may delete file after extraction)
  fileKey  String? // disk path or R2 key
  fileUrl  String? // local path or signed URL
  fileName String? // original filename for display

  // Version increments per upload within a job profile
  version Int @default(1)

  // Parsing state
  parseStatus JobStatus @default(PENDING)
  parseError  String?

  // Extracted content
  rawText       String @db.Text
  rawTextLength Int?

  // Structured AI extraction — ResumeParsedData interface
  parsedData Json

  ecosystem Ecosystem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Interviews frozen against this snapshot
  interviews Interview[]

  // Back-relation for JobProfile.activeResume
  activeForJobProfile JobProfile? @relation("ActiveResume")

  @@index([jobProfileId])
  @@index([jobProfileId, version])
  @@index([parseStatus])
}

// ======================================================
// INTERVIEW
// Why: Core product entity. One interview session end-to-end.
//      Frozen against one resume snapshot.
//      Contains the full adaptive conversation + activities + report.
// ======================================================

model Interview {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobProfileId String
  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)

  // Frozen resume snapshot — never changes after interview creation
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id])

  // Interview classification
  type InterviewType @default(FULL)
  mode InterviewMode @default(MIXED)

  // Candidate chose: 'technical_only' | 'hr_technical' | 'full'
  // Stored separately because InterviewType maps role, not format
  interviewFormat String @default("full")

  status InterviewStatus @default(PENDING)

  title String? // e.g. "Frontend Engineer — Round 2"

  // Pre-generated plan from AI planner before first question
  interviewPlan Json?
  planGenerated Boolean @default(false)

  // Progress tracking
  totalQuestions      Int @default(8)
  currentTurnIndex    Int @default(0)
  activitiesCompleted Int @default(0)
  activitiesPlanned   Int @default(0)

  // Scores — populated progressively, finalised in report
  overallScore       Int?
  communicationScore Int?
  technicalScore     Int?
  confidenceScore    Int?
  authenticityScore  Int? // cross-validates resume claims vs interview answers

  // Aggregated after report generation
  weakTopics   String[]
  strongTopics String[]

  // Realtime channel — required for Ably state sync + recovery
  ablyChannelId String?

  // Timing
  durationSeconds Int?
  startedAt       DateTime?
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  turns       InterviewTurn[]
  activities  InterviewActivity[]
  analytics   InterviewAnalytics?
  report      InterviewReport?
  suggestions ImprovementSuggestion[]

  @@index([userId])
  @@index([status])
  @@index([jobProfileId])
  @@index([resumeId])
  @@index([userId, status])
  @@index([createdAt])
}

// ======================================================
// INTERVIEW TURN
// Why: Every question-answer exchange stored individually.
//      The conversational intelligence layer.
//      Powers adaptive follow-ups, scoring, and fine-tuning data.
// ======================================================

model InterviewTurn {
  id String @id @default(cuid())

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  turnIndex Int

  // TurnRole.AI = interviewer question | TurnRole.USER = candidate answer
  role TurnRole

  // Question metadata (AI turns only)
  questionCategory    QuestionCategory?
  questionDifficulty  QuestionDifficulty?
  psychologicalIntent PsychologicalIntent?
  targetSkills        String[]

  // Content
  question String? @db.Text // populated on AI turns
  answer   String? @db.Text // populated on USER turns

  // How the candidate responded
  inputMode InputMode?

  // For code activities
  codeSnippetShown  String? @db.Text // code shown to candidate (read-only)
  codeEditorContent String? @db.Text // code written/edited by candidate

  // Voice metadata
  audioKey           String?
  silenceDurationMs  Int? // pause before candidate started speaking
  hesitationDetected Boolean @default(false)
  speechDurationMs   Int? // how long candidate spoke

  // Follow-up tracking
  isFollowUp     Boolean @default(false)
  followUpReason String? // 'shallow_answer' | 'hesitation' | 'resume_claim' | 'pressure'

  // Per-turn scoring (scored on the AI's next turn after reviewing the answer)
  turnScore   Int? // 0–100
  topicScored String? // which JS topic this answer was scored against

  wasInterruption   Boolean @default(false)
  interruptedAiText String? @db.Text // what AI was saying when candidate interrupted

  // Cost tracking
  tokenUsage Int?
  latencyMs  Int?

  createdAt DateTime @default(now())

  @@index([interviewId])
  @@index([interviewId, turnIndex])
}

// ======================================================
// INTERVIEW ACTIVITY
// Why: Practical mini-evaluation tasks mid-interview.
//      One of the core product differentiators.
//      Breaks robotic Q&A flow with real engineering scenarios.
// ======================================================

model InterviewActivity {
  id String @id @default(cuid())

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  activityIndex Int // order within the interview

  type ActivityType

  title  String?
  prompt String  @db.Text // the scenario or question shown to candidate

  // For code activities
  codeSnippet    String? @db.Text // shown to candidate
  expectedAnswer String? @db.Text // internal only — never sent to client

  // Candidate responses
  candidateVoiceAnswer String? @db.Text // STT transcript
  candidateCodeAnswer  String? @db.Text // from react-simple-code-editor
  candidateTextAnswer  String? @db.Text // from textarea

  // Evaluation
  score           Int? // 0–100
  evaluation      Json? // ActivityEvaluation struct
  skillsEvaluated String[]

  // State
  startedAt   DateTime?
  completedAt DateTime?
  skipped     Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewId])
  @@index([interviewId, activityIndex])
}

// ======================================================
// INTERVIEW REPORT
// Why: The core user payoff. Generated async after interview completion.
//      One report per interview. Contains the full evaluation.
// ======================================================

model InterviewReport {
  id String @id @default(cuid())

  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  userId String

  // Headline scores
  overallScore       Int
  communicationScore Int
  technicalScore     Int
  confidenceScore    Int
  authenticityScore  Int? // null if no resume claims were testable

  // Narrative
  performanceSummary String @db.Text // 2–3 sentence honest verdict
  readinessLevel     String // 'not_ready' | 'needs_work' | 'almost_ready' | 'ready'
  readinessSummary   String @db.Text // 1 sentence

  // Structured data — typed in packages/shared/src/types/report.ts
  topStrengths String[] // max 3

  weakTopics    Json // WeakTopic[] — topic, score, evidence, improvement
  topicAnalysis Json // TopicAnalysis[] — topic, score, trend note

  activitySummary Json? // ActivitySummary[] — type, score, note

  communicationAnalysis Json // CommunicationAnalysis struct
  confidenceAnalysis    Json // ConfidenceAnalysis struct
  authenticityAnalysis  Json? // AuthenticityAnalysis struct — null if no claims tested

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([interviewId])
}

// ======================================================
// IMPROVEMENT SUGGESTION
// Why: Post-interview actionable guidance.
//      Instead of LMS: "Open in ChatGPT / Claude" with deep prompts.
//      Keeps MVP lean while still delivering learning value.
// ======================================================

model ImprovementSuggestion {
  id String @id @default(cuid())

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // Direct userId index for cross-interview queries (future)
  userId String

  topic    String // 'async-js' | 'react-performance' | etc.
  priority ImprovementPriority

  title       String
  description String @db.Text // why this matters for their target role

  // The main V1 learning mechanic:
  // A detailed prompt the candidate pastes into ChatGPT or Claude
  learningPrompt String? @db.Text

  // Optional direct resource link
  externalUrl String?

  // Which turns triggered this suggestion
  relatedTurnIds String[]

  dismissed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([interviewId])
  @@index([userId])
  @@index([topic])
  @@index([priority])
}

// ======================================================
// INTERVIEW ANALYTICS
// Why: Operational metrics per interview.
//      Token costs, latency, voice behaviour.
//      Powers cost monitoring and future optimisation.
// ======================================================

model InterviewAnalytics {
  id String @id @default(cuid())

  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // Cost (stored in paise — 1 INR = 100 paise)
  totalTokens    Int?
  totalCostPaise Int?

  // Latency breakdown
  avgLatencyMs    Int?
  avgAiLatencyMs  Int?
  avgSttLatencyMs Int?
  avgTtsLatencyMs Int?

  // Voice behaviour
  totalSpeakingSeconds Int?
  totalSilenceSeconds  Int?
  interruptionCount    Int?
  hesitationCount      Int?
  avgAnswerDurationMs  Int?

  // Completion
  abandonedAtTurn     Int?
  completionRate      Float?
  activitiesCompleted Int?

  createdAt DateTime @default(now())
}

// ======================================================
// INTERVIEW CREDIT
// Why: Credit units that gate interview access.
//      Free signup = 1 credit. Paid sessions = purchased credits.
//      Decoupled from subscriptions for flexibility.
// ======================================================

model InterviewCredit {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  credits Int @default(0)

  // 'signup_free' | 'purchase' | 'subscription' | 'refund' | 'admin_grant'
  reason String?

  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ======================================================
// PAYMENT
// Why: Every Razorpay transaction recorded.
//      Source of truth for billing disputes and reconciliation.
// ======================================================

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountPaise Int // stored in paise for precision (₹49 = 4900)
  currency    String @default("INR")

  provider          String  @default("razorpay")
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?

  status PaymentStatus

  planName       String? // 'session_single' | 'basic_monthly' | 'pro_monthly'
  creditsGranted Int?

  metadata Json? // razorpay notes, webhook payload

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerPaymentId])
}

// ======================================================
// SUBSCRIPTION
// Why: Monthly/annual plan tracking.
//      Determines how many credits are granted and when.
// ======================================================

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planName String // 'basic_monthly' | 'pro_monthly'

  status         SubscriptionStatus
  interviewsLeft Int                @default(0)

  startsAt DateTime
  endsAt   DateTime

  provider      String  @default("razorpay")
  providerSubId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

// ======================================================
// AUDIT LOG
// Why: Security trail. Debugging. Admin review.
//      Record sensitive actions (credit grants, role changes etc.)
// ======================================================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String // 'interview.created' | 'credit.granted' | 'role.changed' etc.
  entity   String? // model name: 'Interview' | 'User' | 'Payment'
  entityId String?

  metadata  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ======================================================
// FEATURE FLAG
// Why: Controlled rollout without code deploys.
//      e.g. TTS, voice mode, new activity types.
// ======================================================

model FeatureFlag {
  id String @id @default(cuid())

  key      String  @unique
  enabled  Boolean @default(false)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ======================================================
// RECRUITER PROFILE (Phase 5 stub)
// Why: Schema exists now so future migration is additive not breaking.
//      No recruiter features in V1.
// ======================================================
