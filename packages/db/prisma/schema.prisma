generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// ENUMS
// ======================================================

enum UserRole {
  CANDIDATE
  ADMIN
}

enum Ecosystem {
  JAVASCRIPT
  PYTHON
  JAVA
  GO
  OTHER
}

enum ExperienceLevel {
  FRESHER // 0 years
  JUNIOR // 0–2 years
  MID // 2–5 years
  SENIOR // 5+ years
}

enum InterviewStatus {
  PENDING // Created, plan generated, not yet started
  ACTIVE // First question delivered, credit consumed
  PAUSED // Candidate paused or platform saved state
  COMPLETED // All questions done, report generating
  FAILED // Unrecoverable error mid-interview
  CANCELLED // Candidate abandoned deliberately
}

enum InterviewType {
  MOCK // General practice
  TECHNICAL // Deep technical only
  HR // HR + behavioural only
  SYSTEM_DESIGN // Architecture focused
  BEHAVIORAL // Behavioural + communication
  FULL // HR + Technical + Activities (default)
}

enum InterviewMode {
  TEXT // Text input only
  VOICE // Voice input, no TTS (AI always types)
  MIXED // Voice preferred, text fallback
}

// Candidate-facing label → internal progression strategy
enum DifficultyProgression {
  GRADUAL // 🟢 Warm Up   — easy → medium → hard
  ADAPTIVE // 🟡 Balanced  — adjusts based on running judge scores (default)
  INTENSIVE // 🔴 Challenge — hard baseline from question 1
}

enum QuestionGenMode {
  HYBRID // Intents fixed at creation, question text generated when topic opens
  // Only mode supported for now — enum kept for future flexibility
}

enum ReportDepth {
  MINIMAL // Overall score + 3-line summary (free tier)
  STANDARD // Scores + topic analysis + suggestions
  DETAILED // Everything + per-question breakdown + authenticity analysis
  EXHAUSTIVE // Everything + raw judge data + full topic evidence
}

enum QuestionType {
  QA // Standard question-answer topic
  ACTIVITY // Interactive task (debugging, code correction, etc.)
}

enum TopicStatus {
  PENDING // Not yet reached in interview sequence
  ACTIVE // Candidate is currently on this topic
  CLOSED // Completed — judge ran or is running
  SKIPPED // Candidate skipped or interview ended before this was reached
}

enum TopicCloseReason {
  TOPIC_TIME_LIMIT_REACHED // Fallback timer fired — no candidate response
  MAX_FOLLOWUPS_REACHED // Hit maxFollowUpsPerTopic from config
  MAX_CLARIFICATION_REACHED // Hit maxClarificationsPerTopic from config
  AI_COMPLETED // AI decided answer sufficient, set moveToNext: true
  USER_SKIPPED // Candidate explicitly said next/skip
  INTERVIEW_PAUSED // Saved mid-topic due to pause
  INTERVIEW_ENDED // Interview ended before this topic closed naturally
}

enum TurnRole {
  AI // Interviewer — question, follow-up, hint, closure
  USER // Candidate — answer, clarification, code submission
}

enum TurnType {
  // AI turn types
  QUESTION // Opening question for this topic
  FOLLOWUP // AI probing deeper on same topic
  CLARIFICATION_RESPONSE // AI re-explaining after candidate confusion
  HINT // Activity only — nudges without revealing answer
  TOPIC_CLOSURE // AI closes the topic with a summary message

  // USER turn types
  ANSWER // Main answer to the question
  FOLLOWUP_ANSWER // Answer to a follow-up probe
  CLARIFICATION_REQUEST // "Can you repeat?" / "What do you mean by X?"
  HINT_REQUEST // Activity only — candidate asks for a nudge
  CODE_SUBMISSION // Activity only — final code written in editor
  SKIP_REQUEST // Candidate wants to move on
}

enum ActivityType {
  DEBUGGING // Find and explain bug in code
  CODE_CORRECTION // Fix broken code in editor
  OUTPUT_PREDICTION // Predict execution result
  PRIORITISATION // Rank actions/scenarios
}

enum InputMode {
  VOICE // Candidate speaks only
  TEXT // Textarea only
  CODE_EDITOR // react-simple-code-editor only
  VOICE_AND_CODE // Voice explanation + editable code
  VOICE_AND_TEXT // Voice explanation + textarea
}

enum QuestionCategory {
  HR
  RESUME_BASED
  CONCEPTUAL
  SCENARIO
  BEHAVIORAL
  SYSTEM_DESIGN
  ACTIVITY
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum PsychologicalIntent {
  EXPLORE
  VALIDATE
  CHALLENGE
}

enum ImprovementPriority {
  CRITICAL // Fix before next interview
  HIGH // Important for target role
  MEDIUM // Good to address
  LOW // Nice to have
}

enum PauseReason {
  USER_PAUSED // Candidate clicked pause deliberately
  PLATFORM_FAILURE // Server error — auto-saved
  BROWSER_CRASH // Client detected unclean exit — auto-saved on recovery
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingInterval {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum VisibilityStatus {
  PRIVATE
  PUBLIC
  RECRUITER_VISIBLE
}

// ======================================================
// PLAN CONFIG
// Why: The flat technical behaviour specification for a
//      tier. Controls every aspect of the interview engine:
//      planner, pause limits, difficulty options,
//      resume parser depth, report depth, and AI models.
//
//      Admin-managed. One record per tier or context.
//      Frozen as a JSON snapshot onto every Interview at
//      creation time — admin changes never affect interviews
//      that are already created or in progress.
//
//      Named PlanConfig because it is the technical spec
//      behind a Plan. Plan = what you sell.
//      PlanConfig = how it behaves.
// ======================================================

model PlanConfig {
  id        String  @id @default(cuid())
  name      String  @unique // "free" | "pro" | "enterprise" | "dev"
  isDefault Boolean @default(false) // used when user has no active subscription
  isActive  Boolean @default(true)

  // ── PLANNER CONTROLS ──────────────────────────────────────
  // targetTopics: core Q&A count — follow-ups never count against this
  targetTopics              Int @default(8)
  maxFollowUpsPerTopic      Int @default(2) // how deep AI probes per topic
  maxClarificationsPerTopic Int @default(2) // how many clarifications per topic

  // Activity composition — JSON map of ActivityType → count
  // e.g. {"DEBUGGING": 2, "CODE_CORRECTION": 1, "SYSTEM_DESIGN_MINI": 1}
  // Set all values to 0 for pure Q&A during dev/testing
  activityConfig Json @default("{}")

  // ── INACTIVITY FALLBACK TIMER ─────────────────────────────
  // Topics close via AI logic (moveToNext) or candidate action first.
  // This timer is the safety net — fires only when candidate goes silent.
  defaultTopicTimeLimitSecs Int @default(600) // Default time budget for a topic. Used when InterviewTopic.timeLimitSeconds is null.

  // ── PAUSE / RESUME CONTROLS ───────────────────────────────
  maxPauseCount       Int @default(2) // how many times candidate can pause
  resumeDeadlineHours Int @default(24) // hours before a paused interview expires

  // ── DIFFICULTY CONTROLS ───────────────────────────────────
  // Filters which DifficultyProgression options the candidate may choose.
  // Free tier example: [GRADUAL] — no choice, always warm up
  // Pro example:       [GRADUAL, ADAPTIVE, INTENSIVE] — full choice
  allowedDifficultyModes DifficultyProgression[] @default([GRADUAL, ADAPTIVE, INTENSIVE])

  // ── RESUME PARSER CONTROLS ────────────────────────────────
  parseFullResume      Boolean @default(false) // exhaustive extraction when true
  maxProjectsToExtract Int     @default(3) // ignored if parseFullResume = true
  maxSkillsPerCategory Int     @default(10) // ignored if parseFullResume = true
  maxExperienceYears   Int     @default(10) // how far back to read work history

  // ── REPORT CONTROLS ───────────────────────────────────────
  // reportDepth drives all report section gates:
  //   MINIMAL    → scores + summary only
  //   STANDARD   → + topic analysis + suggestions
  //   DETAILED   → + per-question breakdown + authenticity analysis + activity report
  //   EXHAUSTIVE → + raw judge data + full topic evidence
  reportDepth      ReportDepth @default(STANDARD)
  reportUnlockable Boolean     @default(false) // Upsell gate — teaser shown, full report costs 1 credit

  // ── QUESTION GENERATION MODE ──────────────────────────────
  questionGenMode QuestionGenMode @default(HYBRID)

  // ── RATE LIMITS & QUOTAS ─────────────────────────────────
  maxResumeUploadsPerJobProfile Int @default(1) // Free=1, Pro=many
  maxResumeUploadsPerDay        Int @default(1)
  maxJobProfiles                Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  plans Plan[]

  @@index([isDefault])
  @@index([isActive])
}

// ======================================================
// PLAN
// Why: The product definition layer. What you sell.
//      Separates the commercial product (price, name,
//      credits, billing interval) from the technical
//      behaviour (PlanConfig).
//
//      One Plan points to one PlanConfig.
//      One PlanConfig can back multiple Plans
//      (e.g. "Pro Monthly" and "Pro Yearly" both use
//      the same "pro" PlanConfig).
//
//      Admin-managed. Displayed on the pricing page.
//      Users subscribe to a Plan.
// ======================================================

model Plan {
  id          String  @id @default(cuid())
  name        String  @unique // "free" | "pro_monthly" | "pro_yearly" | "enterprise"
  displayName String // "Pro Plan" — shown in UI and invoices
  description String? // optional tagline for the pricing page

  // Pricing — stored in paise (1 INR = 100 paise). Null for free tier.
  amountPaise     Int?
  billingInterval BillingInterval @default(ONE_TIME)

  // Interview credits granted at the start of each billing period
  // or immediately on one-time purchase
  includedCredits Int @default(1)

  // Technical behaviour for this plan
  planConfigId String
  planConfig   PlanConfig @relation(fields: [planConfigId], references: [id])

  isActive  Boolean @default(true)
  isVisible Boolean @default(true) // false hides plan from pricing page (e.g. legacy plans)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions Subscription[]
  payments      Payment[]

  @@index([isActive])
  @@index([isVisible])
}

// ======================================================
// USER
// Why: Core identity. Owns job profiles, billing, auth.
// ======================================================

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  role UserRole @default(CANDIDATE)

  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  // This is used to reward the candidate for joining the interview.
  joiningBonusGranted Boolean @default(false)

  visibilityStatus VisibilityStatus @default(PRIVATE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  jobProfiles   JobProfile[]
  interviews    Interview[]
  subscriptions Subscription[]
  payments      Payment[]
  credits       Credit[]
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
}

// ======================================================
// BETTER AUTH — SESSION
// ======================================================

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@map("AuthSession")
}

// ======================================================
// BETTER AUTH — ACCOUNT
// ======================================================

model Account {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId  String
  providerId String

  accessToken  String?
  refreshToken String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String?
  idToken  String?
  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// ======================================================
// BETTER AUTH — VERIFICATION
// ======================================================

model Verification {
  id String @id @default(cuid())

  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
}

// ======================================================
// JOB PROFILE
// Why: The primary preparation journey object.
//      One user → many profiles (Frontend, Backend, etc.)
//      All interviews and resumes live inside a profile.
// ======================================================

model JobProfile {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String // e.g. "Frontend Engineer at Startups"
  targetRole  String // e.g. "Frontend Engineer"
  description String? // optional notes about the preparation goal

  experienceLevel ExperienceLevel
  ecosystem       Ecosystem?

  // Points to the resume snapshot used for future interviews.
  // Null until first resume is uploaded.
  activeResumeId String? @unique
  activeResume   Resume? @relation("ActiveResume", fields: [activeResumeId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes    Resume[]
  interviews Interview[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([targetRole])
}

// ======================================================
// RESUME SNAPSHOT
// Why: Each upload creates a NEW immutable snapshot.
//      Interviews are frozen against the snapshot they
//      were generated from. Guarantees historical
//      correctness and reproducible reports.
// ======================================================

model Resume {
  id String @id @default(cuid())

  jobProfileId String
  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)

  fileKey  String?
  fileUrl  String?
  fileName String?

  // Increments per upload within a job profile
  version Int @default(1)

  parseStatus JobStatus @default(PENDING)
  parseError  String?

  rawText       String @db.Text
  rawTextLength Int?

  // Structured AI extraction — ResumeParsedData interface
  // Contains: name, experienceLevel, projects, skills,
  // claimsToValidate, inferredWeakAreas, workHistory
  parsedData Json

  ecosystem Ecosystem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interviews          Interview[]
  activeForJobProfile JobProfile? @relation("ActiveResume")

  @@index([jobProfileId])
  @@index([jobProfileId, version])
  @@index([parseStatus])
}

// ======================================================
// INTERVIEW
// Why: Core product entity. One end-to-end interview session.
//      Frozen against one resume snapshot and one PlanConfig
//      snapshot. Contains the adaptive topic sequence,
//      pause state, scores, and links to the final report.
// ======================================================

model Interview {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobProfileId String
  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)

  // Frozen resume snapshot — never changes after creation
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id])

  // Resume parsedData copied at creation time.
  // Protects against resume record deletion after interview creation.
  resumeSnapshot Json?

  // Interview classification
  type   InterviewType   @default(FULL)
  mode   InterviewMode   @default(MIXED)
  status InterviewStatus @default(PENDING)

  title String? // e.g. "Frontend Engineer — Round 2"

  // ── PLAN CONFIG SNAPSHOT ─────────────────────────────────
  // Full copy of PlanConfig frozen at interview creation time.
  // Admin PlanConfig changes never affect in-progress interviews.
  // planConfigId kept for analytics — which config was active.
  planConfigSnapshot Json
  planConfigId       String?

  // ── DIFFICULTY ───────────────────────────────────────────
  // Candidate's chosen progression mode.
  // Must be within PlanConfig.allowedDifficultyModes.
  difficultyProgression DifficultyProgression @default(ADAPTIVE)

  // ── INTERVIEW PLAN ───────────────────────────────────────
  // Pre-generated topic intents and ordered sequence.
  // Question text is generated dynamically per HYBRID mode
  // when each topic becomes ACTIVE.
  interviewPlan Json?
  planGenerated Boolean   @default(false)
  planStatus    JobStatus @default(PENDING)
  planError     String?

  // ── PROGRESS ─────────────────────────────────────────────
  totalTopics         Int @default(8) // targetTopics + activities
  currentTopicIndex   Int @default(0) // index of the currently ACTIVE InterviewTopic
  activitiesCompleted Int @default(0)
  activitiesPlanned   Int @default(0)

  // ── PAUSE / RESUME ───────────────────────────────────────
  pauseCount     Int          @default(0)
  maxPauseCount  Int // copied from planConfig at creation
  pausedAt       DateTime?
  pauseReason    PauseReason?
  resumeDeadline DateTime? // = pausedAt + planConfig.resumeDeadlineHours

  // ── SCORES (progressive — finalised after report) ────────
  overallScore       Int?
  communicationScore Int?
  technicalScore     Int?
  confidenceScore    Int?
  authenticityScore  Int? // cross-validates resume claims vs answers

  // ── AGGREGATED AFTER REPORT ──────────────────────────────
  feedback     String?
  weakTopics   String[]
  strongTopics String[]

  // ── TIMING ───────────────────────────────────────────────
  durationSeconds Int?
  startedAt       DateTime?
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  topics      InterviewTopic[]
  analytics   InterviewAnalytics?
  report      InterviewReport?
  suggestions ImprovementSuggestion[]

  @@index([userId])
  @@index([status])
  @@index([jobProfileId])
  @@index([resumeId])
  @@index([userId, status])
  @@index([createdAt])
}

// ======================================================
// INTERVIEW TOPIC
// Why: The core architectural unit of the interview.
//      Each planned topic is a self-contained conversation
//      thread. All turns live inside it — clarifications,
//      follow-ups, hints, code submissions.
//      Judge result lives here.
//      Only the judgeSummary crosses topic boundaries.
//
//      The quota counter is topicIndex.
//      Follow-up turns inside a topic never increment it.
// ======================================================

model InterviewTopic {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // 1..N — the quota counter.
  // Both QA and ACTIVITY types count toward this total.
  // Follow-up and clarification turns do NOT increment this.
  topicIndex Int

  type QuestionType // QA | ACTIVITY

  // ── PLANNED AT CREATION (always populated) ────────────────
  plannedIntent     PsychologicalIntent?
  plannedCategory   QuestionCategory?
  targetSkills      String[]
  plannedDifficulty QuestionDifficulty?

  // ── GENERATED WHEN TOPIC OPENS (HYBRID mode) ─────────────
  // Null until this topic becomes ACTIVE.
  // Generated using prior topic summaries + planned intent +
  // candidate's running performance (for ADAPTIVE difficulty).
  questionText String? @db.Text

  // ── ACTIVITY-ONLY FIELDS ─────────────────────────────────
  activityType   ActivityType?
  codeSnippet    String?       @db.Text // shown to candidate in code editor
  expectedAnswer String?       @db.Text // NEVER sent to client — judge reads internally

  // Per-topic window — how long the candidate will get time for this topic.
  timeLimitSeconds Int?
  remainingSeconds Int?

  // ── TIMING ───────────────────────────────────────────────
  timeUsedSeconds Int? // how long candidate actually took

  // ── STATE ────────────────────────────────────────────────
  status      TopicStatus       @default(PENDING)
  closeReason TopicCloseReason?
  startedAt   DateTime?
  closedAt    DateTime?

  // ── JUDGE RESULT ─────────────────────────────────────────
  // Populated async after topic closes.
  // Runs in parallel with next topic streaming —
  // candidate never waits for the judge.
  judgeSummary    String?   @db.Text // 1–2 sentences — context for future topics
  judgeScore      Int? // 0–100
  judgeStrengths  String[]
  judgeWeaknesses String[]
  judgePending    Boolean   @default(false) // true while judge job is in flight
  judgeRetryCount Int       @default(0) // auto-retried up to 3 times on failure
  judgedAt        DateTime?

  turns TopicTurn[]

  @@unique([interviewId, topicIndex])
  @@index([interviewId])
  @@index([interviewId, status])
}

// ======================================================
// INTERVIEW TURN
// Why: Every single exchange within a topic.
//      Voice transcript, typed text, and code submissions
//      all land in one unified content field.
//      TurnType tells you how to interpret the content.
//      No parallel fields. Single source of truth for
//      all candidate input regardless of input mode.
// ======================================================

model TopicTurn {
  id      String         @id @default(cuid())
  topicId String
  topic   InterviewTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // Denormalized — avoids joining through InterviewTopic
  // for queries that need all turns across an interview
  interviewId String

  // Sequential within this topic. Starts at 0.
  // AI opening question is always turnIndex = 0.
  turnIndex Int

  role     TurnRole // AI | USER
  turnType TurnType // semantic meaning of this exchange

  // ── UNIFIED CONTENT ──────────────────────────────────────
  // All input types land here:
  //   Voice input  → Deepgram transcript
  //   Text input   → textarea content
  //   Code input   → editor content (CODE_SUBMISSION turns)
  content String? @db.Text

  // ── AI TURN METADATA ─────────────────────────────────────
  moveToNext         Boolean    @default(false) // AI signals topic should close after this turn
  suggestedInputMode InputMode? // what input the frontend should show next

  // ── PERFORMANCE ──────────────────────────────────────────
  latencyMs          Int? // server: time from request received to first token sent
  streamingLatencyMs Int? // client: time from action call to first token rendered
  timeUsedSeconds    Int?
  tokenUsage         Int?

  createdAt DateTime @default(now())

  @@unique([topicId, turnIndex])
  @@index([topicId])
  @@index([interviewId])
  @@index([interviewId, turnIndex])
}

// ======================================================
// INTERVIEW REPORT
// Why: The core user payoff. Generated async by BullMQ
//      worker after interview completes.
//      Report generator reads only judge summaries per
//      topic — never raw turns. This keeps the prompt
//      small and fast regardless of interview length.
// ======================================================

model InterviewReport {
  id          String    @id @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId      String

  // ── HEADLINE SCORES ───────────────────────────────────────
  overallScore       Int
  communicationScore Int
  technicalScore     Int
  confidenceScore    Int
  authenticityScore  Int? // null if no resume claims were testable

  // ── NARRATIVE ────────────────────────────────────────────
  performanceSummary String @db.Text // 2–3 sentence honest verdict
  readinessLevel     String // 'not_ready' | 'needs_work' | 'almost_ready' | 'ready'
  readinessSummary   String @db.Text // 1 sentence

  // ── STRUCTURED DATA ───────────────────────────────────────
  topStrengths String[] // max 3

  // WeakTopic[] — topic, score, evidence, improvement
  weakTopics Json

  // TopicAnalysis[] — topic, score, trend note
  topicAnalysis Json

  // ActivitySummary[] — type, score, note
  // Populated only when reportDepth >= DETAILED
  activitySummary Json?

  // CommunicationAnalysis struct
  communicationAnalysis Json

  // ConfidenceAnalysis struct
  confidenceAnalysis Json

  // AuthenticityAnalysis struct
  // Populated only when reportDepth >= DETAILED
  authenticityAnalysis Json?

  // QuestionBreakdown[] — score, strengths, weaknesses per topic
  // Populated only when reportDepth >= DETAILED
  questionBreakdown Json?

  // Depth used to generate this report — from planConfigSnapshot
  reportDepth ReportDepth

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([interviewId])
}

// ======================================================
// IMPROVEMENT SUGGESTION
// Why: Post-interview actionable guidance.
//      V1 mechanic: a detailed prompt the candidate pastes
//      into ChatGPT or Claude for a deep tutoring session
//      on each weak topic. Keeps MVP lean while delivering
//      real learning value without building an LMS.
// ======================================================

model ImprovementSuggestion {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId      String

  topic    String // 'async-js' | 'react-performance' etc.
  priority ImprovementPriority // CRITICAL | HIGH | MEDIUM | LOW

  title       String
  description String @db.Text // why this matters for their target role

  // Main V1 learning mechanic:
  // Detailed prompt candidate pastes into ChatGPT or Claude
  learningPrompt String? @db.Text

  externalUrl String?

  // Which topic indices triggered this suggestion
  relatedTopicIds String[]

  dismissed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([interviewId])
  @@index([userId])
  @@index([topic])
  @@index([priority])
}

// ======================================================
// INTERVIEW ANALYTICS
// Why: Operational metrics per interview.
//      Token costs, latency, voice behaviour.
//      Powers cost monitoring and model comparison.
// ======================================================

model InterviewAnalytics {
  id          String    @id @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // Cost — stored in paise (1 INR = 100 paise)
  totalTokens    Int?
  totalCostPaise Int?

  // Latency breakdown
  avgLatencyMs    Int?
  avgAiLatencyMs  Int?
  avgSttLatencyMs Int?

  // Voice behaviour
  totalSpeakingSeconds Int?
  totalSilenceSeconds  Int?
  hesitationCount      Int?
  avgAnswerDurationMs  Int?

  // Completion
  abandonedAtTopic    Int? // topicIndex where candidate left
  completionRate      Float?
  activitiesCompleted Int?
  pauseCount          Int?

  createdAt DateTime @default(now())
}

// ======================================================
// CREDIT
// Why: Ledger of interview credit transactions per user.
//      Each row is one credit event — not a running balance.
//      Balance is always derived: SUM(amount) WHERE not expired.
//
//      Sources: joining_bonus | purchase | subscription | refund | admin_grant
//      Consumed when first question is DELIVERED — not on creation.
// ======================================================

model Credit {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Units of interview access granted (positive) or consumed (negative).
  // e.g. joining_bonus = +1, interview consumed = -1, refund = +1
  amount Int @default(0)

  // 'joining_bonus' | 'purchase' | 'subscription' | 'refund' | 'admin_grant' | 'consumed'
  reason String?

  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, expiresAt])
}

// ======================================================
// PAYMENT
// Why: Every Razorpay transaction recorded.
//      Source of truth for billing disputes and
//      reconciliation. One record per transaction.
// ======================================================

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan reference — null for one-time credit purchases
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  amountPaise Int // stored in paise (₹499 = 49900)
  currency    String @default("INR")

  provider          String  @default("razorpay")
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?

  status PaymentStatus

  creditsGranted Int?

  metadata Json? // razorpay webhook payload, notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerPaymentId])
  @@index([planId])
}

// ======================================================
// SUBSCRIPTION
// Why: A specific user's active purchase of a Plan.
//      Tracks billing period and payment provider reference.
//
//      User → Subscription → Plan → PlanConfig
//      This chain resolves the technical behaviour
//      for any interview the user creates.
// ======================================================

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status SubscriptionStatus

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  provider      String  @default("razorpay")
  providerSubId String? // Razorpay subscription ID for webhook matching

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([providerSubId])
}

// ======================================================
// AUDIT LOG
// Why: Security trail, debugging, and admin review.
//      Records every sensitive action with full context.
// ======================================================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // e.g. 'interview.created' | 'credit.granted' | 'role.changed' | 'plan.updated'
  action   String
  entity   String? // 'Interview' | 'User' | 'Payment' | 'Plan' | 'PlanConfig'
  entityId String?

  metadata  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ======================================================
// FEATURE FLAG
// Why: Controlled rollout without code deploys.
//      e.g. 'voice_mode' | 'activity_hints' | 'exhaustive_report'
// ======================================================

model FeatureFlag {
  id String @id @default(cuid())

  key      String  @unique
  enabled  Boolean @default(false)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
